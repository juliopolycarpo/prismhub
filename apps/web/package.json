{
  "name": "@prismhub/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React + Vite dashboard served at /dashboard.",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "typecheck": "tsc --noEmit --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:integration": "bun test integration.test",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.2.0",
    "@prismhub/app-api": "workspace:*",
    "@prismhub/contracts": "workspace:*",
    "@prismhub/observability": "workspace:*",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-virtual": "^3.13.24",
    "better-auth": "1.6.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.9.0",
    "msw": "^2.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
