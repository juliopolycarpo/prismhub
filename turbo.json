{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "src/**/*.ts", "src/**/*.tsx"],
      "outputs": ["dist/**", "src/manifest.generated.ts", "tsconfig.tsbuildinfo"]
    },
    "compile": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "src/**/*.ts", "src/**/*.tsx"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../eslint.config.js",
        "../../eslint.rules.js",
        "src/**/*.ts",
        "src/**/*.tsx"
      ],
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../tsconfig*.json",
        "tsconfig*.json",
        "src/**/*.ts",
        "src/**/*.tsx"
      ],
      "outputs": ["typecheck.tsbuildinfo", "scripts/typecheck.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "test-setup.ts",
        "vitest.config.ts",
        "bunfig.toml"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "test-setup.ts",
        "vitest.config.ts",
        "bunfig.toml"
      ],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "test-setup.ts",
        "vitest.config.ts",
        "bunfig.toml"
      ],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "test-setup.ts",
        "vitest.config.ts",
        "bunfig.toml"
      ],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "test-setup.ts",
        "vitest.config.ts",
        "bunfig.toml"
      ],
      "outputs": ["coverage/**"]
    },
    "migrate": {
      "cache": false,
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
