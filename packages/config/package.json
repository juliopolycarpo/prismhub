{
  "name": "@prismhub/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runtime configuration, environment parsing, and filesystem paths.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:unit": "bun test unit.test",
    "test:integration": "bun test integration.test",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@prismhub/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
