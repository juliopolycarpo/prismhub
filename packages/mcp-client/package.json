{
  "name": "@prismhub/mcp-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Upstream MCP connection pool and tool list/call wrapper.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:unit": "bun test unit.test",
    "test:integration": "bun test integration.test",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prismhub/config": "workspace:*",
    "@prismhub/contracts": "workspace:*",
    "@prismhub/core": "workspace:*",
    "@prismhub/observability": "workspace:*"
  },
  "devDependencies": {
    "@prismhub/mcp-core": "workspace:*",
    "@prismhub/mcp-host": "workspace:*",
    "elysia": "^1.2.0",
    "typescript": "^5.7.3"
  }
}
