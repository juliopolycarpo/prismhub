{
  "name": "@prismhub/observability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stderr-safe logger, structured error base, and audit helpers.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:unit": "bun test unit.test",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@prismhub/config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
