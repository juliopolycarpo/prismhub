{
  "name": "@prismhub/integration-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-cutting repo-wide integration tests (policy guards, lint-like assertions).",
  "exports": {},
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit --tsBuildInfoFile typecheck.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "test": "bun test",
    "test:unit": "bun test unit.test",
    "test:integration": "bun test integration.test",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
