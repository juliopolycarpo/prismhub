# Prismhub environment configuration example.
# Copy this file to .env and fill in the values as needed.
# Variables marked "# required" have no default and must be set explicitly.

# ─── HTTP Server ─────────────────────────────────────────────────────────────

# Hostname or IP address to bind the HTTP server to.
# Binding to 0.0.0.0 / :: requires PRISMHUB_TRUST_NON_LOCAL=1.
PRISMHUB_HOST=127.0.0.1

# TCP port to listen on (1–65535).
PRISMHUB_PORT=3030

# Allow binding to non-local addresses (0.0.0.0, ::, ::0).
# Set to 1 only when deliberately exposing Prismhub on the network.
PRISMHUB_TRUST_NON_LOCAL=0

# ─── Stdio ───────────────────────────────────────────────────────────────────

# Set to 1 to redirect structured logs to stderr instead of stdout.
# Useful when running inside a supervisor that captures stdout separately.
PRISMHUB_STDIO=0

# ─── Logging ─────────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
PRISMHUB_LOG_LEVEL=info

# ─── Paths ───────────────────────────────────────────────────────────────────

# Root data directory for the database, pidfile, and logs.
# Supports ~ expansion. Default: ~/.prismhub
# PRISMHUB_DATA_DIR=~/.prismhub

# ─── Runtime ─────────────────────────────────────────────────────────────────

# Application environment: development | production | test
NODE_ENV=development
# ─── Authentication (Better Auth) ─────────────────────────────────────

# Secret used to sign auth cookies and tokens. Required in production.
# Generate with: openssl rand -base64 32
# Must be at least 32 characters long.
# BETTER_AUTH_SECRET=

# Optional override for the public base URL of the Prismhub server.
# Defaults to http://${PRISMHUB_HOST}:${PRISMHUB_PORT}.
# BETTER_AUTH_URL=
